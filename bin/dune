(executable
 (name iii)
 (public_name iii)
 (modes exe)
 (modules iii)
 (flags
  (-cclib -lstdc++ -linkall))
 (libraries libISA linenoise))

(install
 (section share)
 (files
  (../stdlib.isa as stdlib/stdlib.isa)
