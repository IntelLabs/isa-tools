{
  "name": "isa-language",
  "displayName": "ISA Language",
  "description": "Syntax Highlighting for ISA",
  "version": "0.0.4",
  "publisher": "intel-rbarbalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/intel-innersource/libraries.isa.isa.isa-interpreter"},
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "isa",
      "aliases": ["ISA", "isa"],
      "extensions": [".isa"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "isa",
      "scopeName": "source.isa",
      "path": "./syntaxes/isa.tmLanguage.json"
    }]
  }
}
