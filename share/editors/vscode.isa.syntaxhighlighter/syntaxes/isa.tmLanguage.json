{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "ISA",
	"patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#operators"
        },
        {
			"include": "#keywords"
		},
		{
            "include": "#functions"
        },
		{
			"include": "#strings"
		},
		{
            "include": "#numbers"
        },
        {
            "include": "#storage"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#returns"
        },
        {
            "include": "#assignments"
        },
        {
            "include": "#variables"
        }
	],
	"repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.isa",
                    "match": "//.*$"
                }
            ]
        },
		"functions": {
            "patterns": [
                {
                    "name": "entity.name.function.isa",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*\\("
                },
                {
                    "name": "entity.name.function.declaration.isa",
                    "match": "(?<=\\bfunction\\b\\s+)\\w+"
                }
            ]
        },
		"keywords": {
			"patterns": [{
				"name": "keyword.control.isa",
				"match": "\\b(begin|end|if|then|elsif|else|endif|for|to|downto|endfor|while|doendwhile|case|of|when|endcase|return|otherwise|others|type|try|catch|endtry|assert|throw|function|implicit|UNSPECIFIED|module|endmodule|interface|file|import|export|use|foreign|optimize|let|var|pure|impure|ordered|unordered|__builtin)\\b"
			}]
		},
		"operators": {
            "patterns": [
                {
                    "name": "keyword.operator.isa",
                    "match": "\\b(and|or|xor|not|with)\\b"
                }
            ]
        },
		"strings": {
			"name": "string.quoted.double.isa",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.isa",
					"match": "\\\\."
				}
			]
		},
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.isa",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.hex.isa",
                    "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.isa",
                    "match": "\\b0b[01_]+\\b"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "name": "storage.type.isa",
                    "match": "\\b(var|let|record|enumeration|array|exception|Bit|Bits|Integer|Boolean|String)\\b"
                }
            ]
        },
		"assignments": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.isa",
                    "match": ":="
                }
            ]
        },
		"returns": {
            "patterns": [
                {
                    "name": "keyword.control.return.isa",
                    "match": "->"
                }
            ]
		},
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.isa",
                    "match": "\\b(True|False)\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.isa",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
	},
	"scopeName": "source.isa"
}
