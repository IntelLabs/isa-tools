<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd"
[
    <!ENTITY int "(?:[0-9_]++)">
    <!ENTITY hex_int "(?:[0-9A-Fa-f_]++)">
    <!ENTITY bitvector "(?:[01x_]++)">
]>
<language name="ISA" section="Sources"
          version="0.1"
          kateversion="6.0"
          casesensitive="1"
          extensions="*.isa">
  <highlighting>
    <list name="controlflow">
      <item>begin</item>
      <item>case</item>
      <item>catch</item>
      <item>do</item>
      <item>downto</item>
      <item>else</item>
      <item>elsif</item>
      <item>end</item>
      <item>endcase</item>
      <item>endfor</item>
      <item>endif</item>
      <item>endtry</item>
      <item>endwhile</item>
      <item>function</item>
      <item>for</item>
      <item>if</item>
      <item>otherwise</item>
      <item>others</item>
      <item>repeat</item>
      <item>return</item>
      <item>then</item>
      <item>throw</item>
      <item>to</item>
      <item>try</item>
      <item>until</item>
      <item>with</item>
      <item>while</item>
    </list>
    <list name="keywords">
      <item>UNSPECIFIED</item>
      <item>and</item>
      <item>array</item>
      <item>as</item>
      <item>assert</item>
      <item>bitfield</item>
      <item>endmodule</item>
      <item>enumeration</item>
      <item>exception</item>
      <item>export</item>
      <item>file</item>
      <item>foreign</item>
      <item>import</item>
      <item>impure</item>
      <item>in</item>
      <item>interface</item>
      <item>let</item>
      <item>module</item>
      <item>not</item>
      <item>of</item>
      <item>optimize</item>
      <item>or</item>
      <item>pure</item>
      <item>record</item>
      <item>type</item>
      <item>use</item>
      <item>var</item>
      <item>xor</item>
    </list>
    <list name="types">
      <item>Bit</item>
      <item>Bits</item>
      <item>Boolean</item>
      <item>Integer</item>
    </list>
    <contexts>
      <context attribute="Normal Text" lineEndContext="#stay" name="Normal">
        <keyword attribute="Control Flow" context="#stay" String="controlflow"/>
        <keyword attribute="Keyword" context="#stay" String="keywords"/>
        <keyword attribute="Data Type" context="#stay" String="types"/>
        <DetectIdentifier />
      </context>
    </contexts>
    <itemDatas>
      <itemData name="Normal Text"  defStyleNum="dsNormal" spellChecking="false"/>
      <itemData name="Control Flow" defStyleNum="dsControlFlow" spellChecking="false"/>
      <itemData name="Keyword"      defStyleNum="dsKeyword" spellChecking="false"/>
      <itemData name="Data Type"    defStyleNum="dsDataType" spellChecking="false"/>
    </itemDatas>
  </highlighting>
  <general>
    <comments>
      <comment name="singleLine" start="//" />
    </comments>
    <keywords casesensitive="1" />
  </general>
</language>
