var v : Integer;

foreign export var "v" = v;

// CHECK: var v : Integer;
// CHECK: function v_Read.0{}() -> Integer;
// CHECK: function v_Write.0{}(value : Integer) -> ();

// CHECK-NOT: foreign export var "v" = v;
// CHECK:     foreign export function "v_Read" = v_Read.0 with {};
// CHECK:     foreign export function "v_Write" = v_Write.0 with {};

// CHECK:      function v_Read.0{}() -> Integer{{$}}
// CHECK-NEXT: begin
// CHECK-NEXT:     return v;
// CHECK-NEXT: end

// CHECK:      function v_Write.0{}(value : Integer) -> (){{$}}
// CHECK-NEXT: begin
// CHECK-NEXT:     v := value;
// CHECK-NEXT: end
