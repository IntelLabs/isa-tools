// RUN: %iii --batchmode --exec=":xform_monomorphize" --exec=":show F*" %s | filecheck %s
// Copyright (C) 2025-2025 Intel Corporation

function F1(n : Integer, m : Integer) -> Integer
begin
    return n + m;
end

// TODO imported function, hence function definition should not be needed
function F2(n : Integer, m : Integer) -> Integer
begin
    return n + m;
end

function F3(x : Bits(n), m : Integer)
begin
    Std::Print::Bits::Hex(Std::Bits::Zero_Extend(x, m));
end

foreign export function "F1_8" = F1 with {m => 8};

foreign import function "F2_8" = F2 with {m => 8};

foreign import function "F3_2_8" = F3 with {n => 2, m => 8};

// CHECK:      foreign export function "F1_8" = F1_m_8.0 with {};
// CHECK:      foreign import function "F2_8" = F2_m_8.0 with {};
// CHECK:      foreign import function "F3_2_8" = F3_n_2_m_8.0 with {};

// CHECK:      function F1_m_8.0{}(n : Integer) -> Integer{{$}}
// CHECK-NEXT: begin
// CHECK-NEXT:     return n + 8;
// CHECK-NEXT: end

// CHECK:      function F2_m_8.0{}(n : Integer) -> Integer{{$}}
// CHECK-NEXT: begin
// CHECK-NEXT:     return n + 8;
// CHECK-NEXT: end

// CHECK:      function F3_n_2_m_8.0{}(x : Bits(2)) -> (){{$}}
// CHECK-NEXT: begin
// CHECK-NEXT:     Std::Print::Bits::Hex.0(Std::Bits::Zero_Extend.0(x, 8));
// CHECK-NEXT: end
