// RUN: %iii --batchmode --exec=:xform_desugar --exec=:xform_bitslices --exec=":show --format=raw FUT" %s | filecheck %s

// Copyright (C) 2025-2026 Intel Corporation

function FUT()
begin
    var x : Bits(2);
    var y : Bits(2);
    var i : Integer;
    var a : Bits(1);
    var b : Bits(1);

    var r1 := x ++ y;
    // CHECK: var r1 : Bits(Std::Integer::Add.0{}(2, 2)) := Std::Bits::Or.0{4}(Std::Bits::Shift_Left_Logical_Restricted.0{4}(Std::Bits::Zero_Extend.0{2, 4}(x, 4), 2), Std::Bits::Zero_Extend.0{2, 4}(y, 4));


    var r2 := Std::Bits::Zero_Extend(Std::Bits::All_Ones(i), 8);
    // CHECK: var r2 : Bits(8) := Std::Bits::Mk_Mask.0{8}(i, 8);


    var r3 := Std::Bits::Zero_Extend(Std::Bits::Sign_Extend(x, i), 8);
    // CHECK: var r3 : Bits(8) := Std::Bits::And.0{8}(Std::Bits::Sign_Extend.0{2, 8}(x, 8), Std::Bits::Mk_Mask.0{8}(i, 8));

    var r4 : Bits(8) := Std::Bits::Sign_Extend(x, 8 - i) ++ Std::Bits::Sign_Extend(y, i);
    // CHECK: var r4 : Bits(8) := Std::Bits::Or.0{8}(Std::Bits::Shift_Left_Logical_Restricted.0{8}(Std::Bits::And.0{8}(Std::Bits::Sign_Extend.0{2, 8}(x, 8), Std::Bits::Mk_Mask.0{8}(Std::Integer::Subtract.0{}(8, i), 8)), i), Std::Bits::And.0{8}(Std::Bits::Sign_Extend.0{2, 8}(y, 8), Std::Bits::Mk_Mask.0{8}(i, 8)));


    var r5 := Std::Bits::Zero_Extend(Std::Bits::Repeat(a, i), 8);
    // CHECK: var r5 : Bits(8) := Std::Bits::And.0{8}(Std::Bits::Repeat.0{1, 8}(a, 8), Std::Bits::Mk_Mask.0{8}(Std::Integer::Multiply.0{}(1, i), 8));

    var r6 : Bits(8) := Std::Bits::Repeat(a, 8 - i) ++ Std::Bits::Repeat(b, i);
    // CHECK: var r6 : Bits(8) := Std::Bits::Or.0{8}(Std::Bits::Shift_Left_Logical_Restricted.0{8}(Std::Bits::And.0{8}(Std::Bits::Repeat.0{1, 8}(a, 8), Std::Bits::Mk_Mask.0{8}(Std::Integer::Multiply.0{}(1, Std::Integer::Subtract.0{}(8, i)), 8)), i), Std::Bits::And.0{8}(Std::Bits::Repeat.0{1, 8}(b, 8), Std::Bits::Mk_Mask.0{8}(Std::Integer::Multiply.0{}(1, i), 8)));
end
