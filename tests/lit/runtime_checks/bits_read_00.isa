// RUN: %iii --batchmode --runtime-checks --exec=":show --format=raw FUT*" %s | filecheck %s
// Copyright (C) 2025-2026 Intel Corporation

function FUT1(x : Bits(32), i : {0..31}) -> Bits(1)
begin
    return x[i];
    // CHECK: return (__assert Std::Integer::Lt.0{}(i, 32) __in (__assert Std::Integer::Le.0{}(0, i) __in {Bits(32)}x[i]));
end

function FUT2(x : Bits(32), h : {0..31}, l : {0..4}) -> Bits(h-l+1)
begin
    return x[h : l];
    // CHECK: return (__assert Std::Integer::Lt.0{}(h, 32) __in (__assert Std::Integer::Le.0{}(l, Std::Integer::Add.0{}(h, 1)) __in (__assert Std::Integer::Le.0{}(0, l) __in {Bits(32)}x[h : l])));
end


function FUT3(x : Bits(32), j : {0..15}, w : Integer) -> Bits(w)
begin
    return x[j +: w];
    // CHECK: return (__assert Std::Integer::Le.0{}(Std::Integer::Add.0{}(j, w), 32) __in (__assert Std::Integer::Le.0{}(0, w) __in (__assert Std::Integer::Le.0{}(0, j) __in {Bits(32)}x[j +: w])));
end

function FUT4(x : Bits(32), j : {0..8}, w : Integer) -> Bits(w)
begin
    return x[j *: w];
    // CHECK: return (__assert Std::Integer::Le.0{}(Std::Integer::Multiply.0{}(j, w), Std::Integer::Subtract.0{}(32, w)) __in (__assert Std::Integer::Le.0{}(0, w) __in (__assert Std::Integer::Le.0{}(0, j) __in {Bits(32)}x[j *: w])));
end

function FUT5(x : Bits(32), j : {0..15}, w : Integer) -> Bits(w)
begin
    return x[j -: w];
    // CHECK: return (__assert Std::Integer::Le.0{}(w, Std::Integer::Add.0{}(j, 1)) __in (__assert Std::Integer::Le.0{}(0, w) __in (__assert Std::Integer::Lt.0{}(j, 32) __in {Bits(32)}x[j -: w])));
end
