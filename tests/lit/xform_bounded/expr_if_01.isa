// RUN: %aslopt -O0 -Obounded %s | filecheck --check-prefix=XFORM %s
// RUN: %aslrun -O0 -Obounded %s | filecheck %s

// Copyright (C) 2024-2024 Intel Corporation

// Based on UnsignedSat
function FUT(x : Integer) -> {0..255}
begin
    let r := if x >= 256 then 255
             elsif x < 0 then 0
             else x;
    return r;
end

// Note: the code below could be improved further by not applying
// Std::SInt::To_Integer to both branches of the if-expr.
// We are leaving that improvement for the future.
//
// XFORM-LABEL: function FUT.0{}(x : Integer) -> __sint(9){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      let r : Integer := (if Std::Integer::Ge.0{}(x, Std::SInt::To_Integer.0{10}(i10'x256)) then Std::SInt::To_Integer.0{9}(i9'x255) elsif Std::Integer::Lt.0{}(x, Std::SInt::To_Integer.0{1}(i1'x0)) then Std::SInt::To_Integer.0{1}(i1'x0) else x);
// XFORM-NEXT:      return Std::SInt::From_Integer.0{9}(r, 9);
// XFORM-NEXT:  end

function main() -> Integer
begin
    Std::Print::Integer::Dec(FUT(-1));
    // CHECK: 0
    Std::Print::Integer::Dec(FUT(0));
    // CHECK: 0
    Std::Print::Integer::Dec(FUT(1));
    // CHECK: 1
    Std::Print::Integer::Dec(FUT(255));
    // CHECK: 255
    Std::Print::Integer::Dec(FUT(256));
    // CHECK: 255
    return 0;
end
