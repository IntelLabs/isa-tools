// RUN: %aslopt -O0 -Obounded %s | filecheck --check-prefix=XFORM %s
// RUN: %aslrun -O0 -Obounded %s | filecheck %s

// Copyright (C) 2024-2025 Intel Corporation

function FUT(x : {0..14}) -> Bits(4)
begin
    return Std::Bits::From_Integer(x, 4);
end

// XFORM-LABEL: function FUT.0{}(x : __sint(5)) -> Bits(4){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      return Std::SInt::To_Bits.0{5, 4}(x, 4);
// XFORM-NEXT:  end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(FUT(13));
    // CHECK: 4'xd
    return Builtin::Foreign::CInt::From_Integer(0);
end
