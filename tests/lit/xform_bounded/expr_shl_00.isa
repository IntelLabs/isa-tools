// RUN: %aslopt -O0 -Obounded %s | filecheck --check-prefix=XFORM %s
// RUN: %aslrun -Obounded %s | filecheck %s

// Copyright (C) 2024-2025 Intel Corporation

function FUT(x : {0..14}) -> {0..28}
begin
    return x << 1;
end

// XFORM-LABEL: function FUT.0{}(x : __sint(5)) -> __sint(6){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      return Std::SInt::Shift_Left.0{6}(Std::SInt::Resize.0{5, 6}(x, 6), i6'x1);
// XFORM-NEXT:  end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(FUT(13));
    // CHECK: 26
    return Builtin::Foreign::CInt::From_Integer(0);
end
