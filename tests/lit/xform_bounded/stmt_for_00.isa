// RUN: %aslopt -O0 -Obounded %s | filecheck --check-prefix=XFORM %s
// RUN: %aslrun -Obounded %s | filecheck %s
// Copyright (C) 2024-2026 Intel Corporation

function FUT(x : {0..15}) -> {0..100}
begin
    var s : {0..100} := 0;
    for i : {0..15} := 0 to x do
        s := s + i;
    end;
    return s;
end

// XFORM:       function FUT.0{}(x : __sint(5)) -> __sint(8){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      var s : __sint(8) := i8'x0;
// XFORM-NEXT:      for i : __sint(6) := i6'x0 to Std::SInt::Resize.0{5, 6}(x, 6) do
// XFORM-NEXT:          s := Std::SInt::Resize.0{9, 8}(Std::SInt::Add.0{9}(Std::SInt::Resize.0{8, 9}(s, 9), Std::SInt::Resize.0{6, 9}(i, 9)), 8);
// XFORM-NEXT:      end
// XFORM-NEXT:      return s;
// XFORM-NEXT:  end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(FUT(4)); Std::Print("\n");
    // CHECK: 10
    return Builtin::Foreign::CInt::From_Integer(0);
end
