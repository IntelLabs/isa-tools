function FUT() -> {0..15}
begin
    return 3;
end

// XFORM-LABEL: function FUT.0{}() -> __sint(5){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      return i5'x3;
// XFORM-NEXT:  end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(FUT());
    // CHECK: 3
    return Builtin::Foreign::CInt::From_Integer(0);
end
