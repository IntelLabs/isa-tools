// RUN: %aslopt -O0 -Obounded %s | filecheck --check-prefix=XFORM %s
// RUN: %aslrun -O0 -Obounded %s | filecheck %s
// Copyright (C) 2024-2024 Intel Corporation

function FUT(x : {0..8}) -> {0..255} begin
    // The node to be transformed is 'hidden' under a node
    // that does not need to be transformed
    return (if x < 15 then x + 1 else 255);
end

// Note: the code below could be improved further by not applying
// Std::SInt::From_Integer to both branches of the if-expr.
// We are leaving that improvement for the future.
//
// XFORM-LABEL: function FUT.0{}(x : __sint(5)) -> __sint(9){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      return Std::SInt::From_Integer.0{9}((if Std::SInt::Lt.0{5}(x, i5'x15) then Std::SInt::To_Integer.0{6}(Std::SInt::Add.0{6}(Std::SInt::Resize.0{5, 6}(x, 6), Std::SInt::Resize.0{2, 6}(i2'x1, 6))) else Std::SInt::To_Integer.0{9}(i9'x255)), 9);
// XFORM-NEXT:  end

function main() -> Integer
begin
    Std::Print::Integer::Dec(FUT(8));
    // CHECK: 9
    return 0;
end
