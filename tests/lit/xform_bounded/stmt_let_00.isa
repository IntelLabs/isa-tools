function FUT(x : {0..10}) -> {0..10}
begin
    let y := x;
    return y;
end

// XFORM:       function FUT.0{}(x : __sint(5)) -> __sint(5){{$}}
// XFORM-NEXT:  begin
// XFORM-NEXT:      let y : __sint(5) := x;
// XFORM-NEXT:      return y;
// XFORM-NEXT:  end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(FUT(5));
    // CHECK: 5
    return Builtin::Foreign::CInt::From_Integer(0);
end
