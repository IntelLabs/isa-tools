// RUN: %iii --max-errors=10 --check-call-markers --batchmode %s
// Copyright (C) 2023-2025 Intel Corporation

exception E;

function NoThrow() -> Integer
begin
    return 0;
end

function MayThrow?() -> Integer
begin
    // Note: functions that return a value cannot be noreturn
    // so we add an if statement to make it look optional
    if True then throw E; end;
    return 0;
end

function AlwaysThrow!()
begin
    throw E;
end

function F() -> Integer
begin
    // All of the following calls are correctly marked and should not report an error.
    let x := NoThrow();
    let y := MayThrow?();
    AlwaysThrow!();
end
