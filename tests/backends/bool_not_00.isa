function Test(x : Boolean) -> Bits(4)
begin
    return
        (if !x then
            0b1001
        else
            0b1011
        );
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(True)); Print("\n");
    // CHECK: 4'xb
    Std::Print::Bits::Hex(Test(False)); Print("\n");
    // CHECK: 4'x9

    return Builtin::Foreign::CInt::From_Integer(0);
end
