function FUT(x : Integer) -> Integer
begin
    let y := Builtin::Foreign::CInt::From_Integer(x);
    return Builtin::Foreign::CInt::To_Integer(y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Hex(FUT(1)); Print("\n");
    // CHECK: 0x1

    return Builtin::Foreign::CInt::From_Integer(0);
end
