// RUN: %aslrun --runtime-checks %s | filecheck %s
// Copyright (C) 2023-2025 Intel Corporation

var R : array [4] of Bits(32);

function Test(i : {0..3}) -> Bits(32)
begin
    return R[i];
end

function main() -> Integer
begin
    R[0] := 10[0 +: 32];
    R[1] := 11[0 +: 32];
    R[2] := 12[0 +: 32];
    R[3] := 13[0 +: 32];

    Std::Print::Bits::Hex(Test(0)); Print("\n");
    // CHECK: 32'xa
    Std::Print::Bits::Hex(Test(1)); Print("\n");
    // CHECK: 32'xb
    Std::Print::Bits::Hex(Test(2)); Print("\n");
    // CHECK: 32'xc
    Std::Print::Bits::Hex(Test(3)); Print("\n");
    // CHECK: 32'xd

    return 0;
end
