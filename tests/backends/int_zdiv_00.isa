function Test(x : Integer, y : Integer) -> Integer
begin
    return Std::Integer::Truncated_Divide(x, y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(Test(6, 3)); Print("\n");
    // CHECK: 2
    Std::Print::Integer::Dec(Test(-6, 3)); Print("\n");
    // CHECK: -2
    Std::Print::Integer::Dec(Test(5, 3)); Print("\n");
    // CHECK: 1
    Std::Print::Integer::Dec(Test(-5, 3)); Print("\n");
    // CHECK: -1
    Std::Print::Integer::Dec(Test(6, -3)); Print("\n");
    // CHECK: -2
    return Builtin::Foreign::CInt::From_Integer(0);
end
