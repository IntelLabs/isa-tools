var R : array [4] of Bits(32);

function Test(i : __sint(3)) -> Bits(32)
begin
    return R[Std::SInt::To_Integer(i)];
end

function main() -> Builtin::Foreign::CInt
begin
    R[0] := 10[0 +: 32];
    R[1] := 11[0 +: 32];
    R[2] := 12[0 +: 32];
    R[3] := 13[0 +: 32];

    Std::Print::Bits::Hex(Test(i3'd0)); Print("\n");
    // CHECK: 32'xa
    Std::Print::Bits::Hex(Test(i3'd1)); Print("\n");
    // CHECK: 32'xb
    Std::Print::Bits::Hex(Test(i3'd2)); Print("\n");
    // CHECK: 32'xc
    Std::Print::Bits::Hex(Test(i3'd3)); Print("\n");
    // CHECK: 32'xd

    return Builtin::Foreign::CInt::From_Integer(0);
end

