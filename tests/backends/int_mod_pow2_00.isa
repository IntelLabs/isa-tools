function Test(x : Integer, y : Integer) -> Integer
begin
    return Std::Integer::Mod_Power_Of_Two(x, y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(Test(12, 2)); Print("\n");
    // CHECK: 0
    Std::Print::Integer::Dec(Test(13, 2)); Print("\n");
    // CHECK: 1
    Std::Print::Integer::Dec(Test(14, 2)); Print("\n");
    // CHECK: 2
    Std::Print::Integer::Dec(Test(15, 2)); Print("\n");
    // CHECK: 3
    Std::Print::Integer::Dec(Test(16, 2)); Print("\n");
    // CHECK: 0
    return Builtin::Foreign::CInt::From_Integer(0);
end
