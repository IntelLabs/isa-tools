function Test(x : Bits(4)) -> {-8..7}
begin
    return Std::Bits::Signed(x);
end

function main() -> Integer
begin
    Std::Print::Integer::Dec(Test(0b0010)); Print("\n");
    // CHECK: 2
    Std::Print::Integer::Dec(Test(0b1010)); Print("\n");
    // CHECK: -6
    return 0;
end
