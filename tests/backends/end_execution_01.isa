function FUT(x : Bits(4))
begin
    Std::End_Execution(x == 0b0000);
end

function main() -> Builtin::Foreign::CInt
begin
    // this will exit with failure
    FUT(0b0001);

    return Builtin::Foreign::CInt::From_Integer(1);
end
