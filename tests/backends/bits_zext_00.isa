function Test(x : Bits(3)) -> Bits(8)
begin
    return Std::Bits::Zero_Extend(x, 8);
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test(0b110)); Print("\n");
    // CHECK: 8'x6
    Std::Print::Bits::Hex(Test(0b011)); Print("\n");
    // CHECK: 8'x3
    return 0;
end
