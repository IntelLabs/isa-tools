function FUT(x : __sint(8), y : __sint(8)) -> Boolean
begin
    return Std::SInt::Eq(x, y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Boolean(FUT(i8'd1, i8'd2)); Std::Print::String("\n");
    // CHECK: False
    Std::Print::Boolean(FUT(i8'd1, i8'd1)); Std::Print::String("\n");
    // CHECK: True
    return Builtin::Foreign::CInt::From_Integer(0);
end
