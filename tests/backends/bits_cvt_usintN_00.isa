function FUT4(x : Bits(4)) -> __sint(5)
begin
    return Std::SInt::Resize(Std::SInt::Unsigned(x), 5);
end

function main() -> Integer
begin
    Std::Print::SInt::Dec(FUT4(0b0010)); Print("\n");
    // CHECK: i5'd2
    Std::Print::SInt::Dec(FUT4(0b1010)); Print("\n");
    // CHECK: i5'd10
    return 0;
end
