function FUT(x : Bits(4)) -> Bits(4)
begin
    assert x != 0b1111;
    return x;
end

function main() -> Builtin::Foreign::CInt
begin
    // assertion that does not fail
    Std::Print::Bits::Hex(FUT(0b0001)); Print("\n");
    // CHECK: 4'x1

    return Builtin::Foreign::CInt::From_Integer(0);
end
