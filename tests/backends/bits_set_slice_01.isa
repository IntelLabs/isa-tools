function Test(x : Bits(4), y : Bits(4)) -> Bits(16)
begin
    var result : Bits(16);
    result := Std::Bits::Zero(16);

    for i := 0 to 3 do
        if x[i +: 1] == 0b1 then
            result[i * 4 +: 4] := y;
        end;
    end;
    return result;
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(0b1100, 0b1111)); Print("\n");
    // CHECK: 16'xff00
    return Builtin::Foreign::CInt::From_Integer(0);
end
