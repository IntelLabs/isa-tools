function Test(x : Integer) -> Bits(512)
begin
    return Std::Bits::From_Integer(x, 512);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(42)); Print("\n");
    // CHECK: 512'x2a
    Std::Print::Bits::Hex(Test(-1)); Print("\n");
    // CHECK: 512'xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
    return Builtin::Foreign::CInt::From_Integer(0);
end

