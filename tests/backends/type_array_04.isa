var R : array [4] of Bits(32);

function FUT(i : Integer) -> Bits(32)
begin
    return R[i];
end

function main() -> Integer
begin
    R[0] := 10[0 +: 32];
    R[1] := 11[0 +: 32];
    R[2] := 12[0 +: 32];
    R[3] := 13[0 +: 32];

    Std::Print::Bits::Hex(FUT(-1)); Print("\n");
    // CHECK: Evaluation error: assertion failure

    return 0;
end
