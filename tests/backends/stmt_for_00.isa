function Test(x : Integer) -> Integer
begin
    var s := 0;
    for i := 0 to x do
        s := s + i;
    end;
    return s;
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(Test(0)); Print("\n");
    // CHECK: 0
    Std::Print::Integer::Dec(Test(1)); Print("\n");
    // CHECK: 1
    Std::Print::Integer::Dec(Test(3)); Print("\n");
    // CHECK: 6

    return Builtin::Foreign::CInt::From_Integer(0);
end
