function FUT(x : __sint(8)) -> Boolean
begin
    return Std::SInt::Is_Power_Of_Two(x);
end

function main() -> Integer
begin
    Std::Print::Boolean(FUT(i8'd0)); Std::Print::String("\n");
    // CHECK: False
    Std::Print::Boolean(FUT(i8'd1)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(FUT(i8'd2)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(FUT(i8'd3)); Std::Print::String("\n");
    // CHECK: False
    Std::Print::Boolean(FUT(i8'd4)); Std::Print::String("\n");
    // CHECK: True
    return 0;
end
