function FUT(x : Bits(16)) -> Bits(64)
begin
    // This test used to fail in c23 backend due to the subtraction
    // being promoted to signed.
    return Std::Bits::Zero_Extend(Std::Bits::Subtract(x, 16'x1), 64);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(FUT(16'x0)); Print("\n");
    // CHECK: 64'xf
    return Builtin::Foreign::CInt::From_Integer(0);
end
