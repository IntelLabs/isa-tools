exception E;

function Test?(x : Integer) -> Integer
begin
    try
        if x < 0 then
            Std::Print::String("THROWING\n");
            throw E;
        end;
    catch
        when e : E =>
            Std::Print::String("CAUGHT\n");
            return -x;
    end;
    return x;
end

function main() -> Integer
begin
    Std::Print::Integer::Dec(Test?(1)); Print("\n");
    // CHECK: 1
    Std::Print::Integer::Dec(Test?(-2)); Print("\n");
    // CHECK: THROWING
    // CHECK: CAUGHT
    // CHECK: 2
    Std::Print::Integer::Dec(Test?(3)); Print("\n");
    // CHECK: 3

    return 0;
end

