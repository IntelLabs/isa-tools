function FUT(x : Bits(8), y : Bits(8)) -> Boolean
begin
    return Std::Bits::Ne(x, y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Boolean(FUT(8'x1, 8'x1)); Std::Print::String("\n");
    // CHECK: False
    Std::Print::Boolean(FUT(8'x1, 8'x2)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(FUT(8'x2, 8'x1)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(FUT(8'x2, 8'x2)); Std::Print::String("\n");
    // CHECK: False

    return Builtin::Foreign::CInt::From_Integer(0);
end
