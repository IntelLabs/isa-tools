function FUT4(x : Bits(4)) -> __sint(4)
begin
    return Std::SInt::Signed(x);
end

function main() -> Integer
begin
    Std::Print::SInt::Dec(FUT4(0b0010)); Print("\n");
    // CHECK: i4'd2
    Std::Print::SInt::Dec(FUT4(0b1010)); Print("\n");
    // CHECK: -i4'd6
    return 0;
end
