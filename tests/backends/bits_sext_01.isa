// RUN: %aslrun %s | filecheck %s
// REQUIRES: !c23 || wide_bitint
// Copyright (C) 2023-2025 Intel Corporation

function Test_70_140(x : Bits(70)) -> Bits(140)
begin
    return Std::Bits::Sign_Extend(x, 140);
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test_70_140(16384[0 +: 70])); Print("\n");
    // CHECK: 140'x4000
    Std::Print::Bits::Hex(Test_70_140((-16384)[0 +: 70])); Print("\n");
    // CHECK: 140'xfffffffffffffffffffffffffffffffc000

    return 0;
end
