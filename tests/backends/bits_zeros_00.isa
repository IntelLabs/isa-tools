function Test0() -> Bits(0)
begin
    return Std::Bits::Zero(0);
end

function Test6() -> Bits(6)
begin
    return Std::Bits::Zero(6);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test0()); Print("\n");
    // CHECK: 0'x0
    Std::Print::Bits::Hex(Test6()); Print("\n");
    // CHECK: 6'x0
    return Builtin::Foreign::CInt::From_Integer(0);
end
