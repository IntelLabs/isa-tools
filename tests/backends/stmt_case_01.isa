function Test(x : Integer) -> Integer
begin
    case x of
        when 1 => return 3;
        when 2 => return 4;
        when 3,4,5 => return 5;
        // missing otherwise - error if no match
    end;
    return 20; // unreachable
end

function main() -> Integer
begin
    Std::Print::Integer::Dec(Test(0)); Print("\n");
    // CHECK: unmatched case

    return 0;
end

