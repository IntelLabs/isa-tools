function FUT_8_4(x : Bits(8), i : Integer) -> Bits(4)
begin
    return x[i +: 4];
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(FUT_8_4(0b1010_0101, -1)); Print("\n");
    // CHECK: Evaluation error: assertion failure
    return Builtin::Foreign::CInt::From_Integer(0);
end
