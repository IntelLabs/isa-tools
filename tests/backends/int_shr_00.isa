function Test(x : Integer, y : Integer) -> Integer
begin
    return x >> y;
end

function main() -> Integer
begin
    Std::Print::Integer::Dec(Test(27, 0)); Print("\n");
    // CHECK: 27
    Std::Print::Integer::Dec(Test(27, 1)); Print("\n");
    // CHECK: 13
    Std::Print::Integer::Dec(Test(27, 2)); Print("\n");
    // CHECK: 6
    return 0;
end
