function Test(x : Integer, y : Integer) -> Integer
begin
    return x * y;
end

function main() -> Integer
begin
    Std::Print::Integer::Dec(Test(4, 5)); Print("\n");
    // CHECK: 20
    Std::Print::Integer::Dec(Test(0, 2)); Print("\n");
    // CHECK: 0
    Std::Print::Integer::Dec(Test(3, -2)); Print("\n");
    // CHECK: -6
    return 0;
end
