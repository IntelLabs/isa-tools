function Test(x : Integer) -> Integer
begin
    return Std::Integer::Power2(x);
end

function main() -> Integer
begin
    Std::Print::Integer::Dec(Test(3)); Print("\n");
    // CHECK: 8
    Std::Print::Integer::Dec(Test(7)); Print("\n");
    // CHECK: 128
    return 0;
end
