function FUT(x : __sint(8)) -> __sint(8)
begin
    return Std::SInt::Negate(x);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::SInt::Dec(FUT(i8'd4)); Print("\n");
    // CHECK: -i8'd4
    Std::Print::SInt::Dec(FUT(-i8'd5)); Print("\n");
    // CHECK: i8'd5
    Std::Print::SInt::Dec(FUT(i8'd0)); Print("\n");
    // CHECK: i8'd0
    return Builtin::Foreign::CInt::From_Integer(0);
end
