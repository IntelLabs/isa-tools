var R : array [3] of Bits(32);

function FUT(i : Integer, x : Bits(32))
begin
    R[i] := x;
end

function main() -> Integer
begin
    FUT(-1, Std::Bits::Zero(32));
    // CHECK: Evaluation error: assertion failure

    return 0;
end
