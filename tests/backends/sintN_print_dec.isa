// RUN: %aslrun %s | filecheck %s
// Copyright (C) 2023-2025 Intel Corporation

function main() -> Integer
begin
    Std::Print::SInt::Dec(i8'd42); Print("\n");
    // CHECK: i8'd42
    Std::Print::SInt::Dec(-i8'd42); Print("\n");
    // CHECK: -i8'd42

    Std::Print::SInt::Dec(i8'd127); Print("\n");
    // CHECK: i8'd127
    Std::Print::SInt::Dec(-i8'd127); Print("\n");
    // CHECK: -i8'd127
    Std::Print::SInt::Dec(-i8'd128); Print("\n");
    // CHECK: -i8'd128
    return 0;
end
