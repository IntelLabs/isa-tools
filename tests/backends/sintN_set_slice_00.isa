// RUN: %aslrun %s | filecheck %s
// Copyright (C) 2023-2025 Intel Corporation

function Test_8_4(x : Bits(8), i : __sint(4), y : Bits(4)) -> Bits(8)
begin
    var r := x;
    r[Std::SInt::To_Integer(i) +: 4] := y;
    return r;
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test_8_4(0b0000_0000, i4'd0, 0b1111)); Print("\n");
    // CHECK: 8'xf
    Std::Print::Bits::Hex(Test_8_4(0b0000_0000, i4'd1, 0b1111)); Print("\n");
    // CHECK: 8'x1e
    Std::Print::Bits::Hex(Test_8_4(0b0000_0000, i4'd2, 0b1111)); Print("\n");
    // CHECK: 8'x3c
    Std::Print::Bits::Hex(Test_8_4(0b0000_0000, i4'd3, 0b1111)); Print("\n");
    // CHECK: 8'x78
    Std::Print::Bits::Hex(Test_8_4(0b0000_0000, i4'd4, 0b1111)); Print("\n");
    // CHECK: 8'xf0

    Std::Print::Bits::Hex(Test_8_4(0b1111_1111, i4'd0, 0b0000)); Print("\n");
    // CHECK: 8'xf0
    Std::Print::Bits::Hex(Test_8_4(0b1111_1111, i4'd1, 0b0000)); Print("\n");
    // CHECK: 8'xe1
    Std::Print::Bits::Hex(Test_8_4(0b1111_1111, i4'd2, 0b0000)); Print("\n");
    // CHECK: 8'xc3
    Std::Print::Bits::Hex(Test_8_4(0b1111_1111, i4'd3, 0b0000)); Print("\n");
    // CHECK: 8'x87
    Std::Print::Bits::Hex(Test_8_4(0b1111_1111, i4'd4, 0b0000)); Print("\n");
    // CHECK: 8'xf

    return 0;
end
