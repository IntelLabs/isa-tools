function Test(x : Bits(8), y : Bits(8)) -> Bits(8)
begin
    return Std::Bits::Subtract(x, y);
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test(1[0 +: 8], 2[0 +: 8])); Print("\n");
    // CHECK: 8'xff
    Std::Print::Bits::Hex(Test(2[0 +: 8], 1[0 +: 8])); Print("\n");
    // CHECK: 8'x1
    return 0;
end
