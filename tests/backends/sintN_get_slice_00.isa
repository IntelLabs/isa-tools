function Test_8_4(x : Bits(8), i : __sint(4)) -> Bits(4)
begin
    return x[Std::SInt::To_Integer(i) +: 4];
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test_8_4(0b1010_0101, i4'd0)); Print("\n");
    // CHECK: 4'x5
    Std::Print::Bits::Hex(Test_8_4(0b1010_0101, i4'd1)); Print("\n");
    // CHECK: 4'x2
    Std::Print::Bits::Hex(Test_8_4(0b1010_0101, i4'd2)); Print("\n");
    // CHECK: 4'x9
    Std::Print::Bits::Hex(Test_8_4(0b1010_0101, i4'd3)); Print("\n");
    // CHECK: 4'x4
    Std::Print::Bits::Hex(Test_8_4(0b1010_0101, i4'd4)); Print("\n");
    // CHECK: 4'xa

    return 0;
end
