function Test(x : Integer, y : Integer) -> Integer
begin
    return x << y;
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Integer::Dec(Test(3, 0)); Print("\n");
    // CHECK: 3
    Std::Print::Integer::Dec(Test(3, 1)); Print("\n");
    // CHECK: 6
    Std::Print::Integer::Dec(Test(3, 2)); Print("\n");
    // CHECK: 12
    return Builtin::Foreign::CInt::From_Integer(0);
end
