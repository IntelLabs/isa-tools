// RUN: %aslrun %s | filecheck %s
// Copyright (C) 2023-2025 Intel Corporation

var R : array [2] of array [2] of Bits(32);

function Test(i : __sint(2), j : __sint(2)) -> Bits(32)
begin
    return R[Std::SInt::To_Integer(i)][Std::SInt::To_Integer(j)];
end

function main() -> Integer
begin
    R[0][0] := 10[0 +: 32];
    R[0][1] := 11[0 +: 32];
    R[1][0] := 12[0 +: 32];
    R[1][1] := 13[0 +: 32];

    Std::Print::Bits::Hex(Test(i2'd0,i2'd0)); Print("\n");
    // CHECK: 32'xa
    Std::Print::Bits::Hex(Test(i2'd0,i2'd1)); Print("\n");
    // CHECK: 32'xb
    Std::Print::Bits::Hex(Test(i2'd1,i2'd0)); Print("\n");
    // CHECK: 32'xc
    Std::Print::Bits::Hex(Test(i2'd1,i2'd1)); Print("\n");
    // CHECK: 32'xd

    return 0;
end

