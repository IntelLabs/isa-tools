function Test(x : Boolean, y : Boolean) -> Bits(4)
begin
    return
        (if x or else y then
            0b1001
        else
            0b1011
        );
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(True, True)); Print("\n");
    // CHECK: 4'x9
    Std::Print::Bits::Hex(Test(True, False)); Print("\n");
    // CHECK: 4'x9
    Std::Print::Bits::Hex(Test(False, True)); Print("\n");
    // CHECK: 4'x9
    Std::Print::Bits::Hex(Test(False, False)); Print("\n");
    // CHECK: 4'xb

    return Builtin::Foreign::CInt::From_Integer(0);
end
