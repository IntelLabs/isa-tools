function FUT(x : __sint(8), y : __sint(8)) -> __sint(8)
begin
    return Std::SInt::Shift_Right(x, y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::SInt::Dec(FUT(i8'd27, i8'd0)); Print("\n");
    // CHECK: i8'd27
    Std::Print::SInt::Dec(FUT(i8'd27, i8'd1)); Print("\n");
    // CHECK: i8'd13
    Std::Print::SInt::Dec(FUT(i8'd27, i8'd2)); Print("\n");
    // CHECK: i8'd6
    return Builtin::Foreign::CInt::From_Integer(0);
end
