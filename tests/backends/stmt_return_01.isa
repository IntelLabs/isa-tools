function FUT(x : Boolean) -> Boolean
begin
    Std::Print::String("A"); Std::Print::String("\n");
    if x then
        return x;
    end;
    // next statement not reached if x
    Std::Print::String("B"); Std::Print::String("\n");
    return !x;
end

function main() -> Integer
begin
    Std::Print::Boolean(FUT(True)); Std::Print::String("\n");
    // CHECK: A
    // CHECK-NOT: B
    // CHECK: True
    Std::Print::Boolean(FUT(False)); Std::Print::String("\n");
    // CHECK: A
    // CHECK: B
    // CHECK: True

    return 0;
end
