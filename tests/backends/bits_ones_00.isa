function Test0() -> Bits(0)
begin
    return Std::Bits::All_Ones(0);
end

function Test6() -> Bits(6)
begin
    return Std::Bits::All_Ones(6);
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test0()); Print("\n");
    // CHECK: 0'x0
    Std::Print::Bits::Hex(Test6()); Print("\n");
    // CHECK: 6'x3f
    return 0;
end
