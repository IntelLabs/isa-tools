function FUT(x : Bits(4)) -> Bits(4)
begin
    assert x != 0b1111;
    return x;
end

function main() -> Integer
begin
    // assertion that does fail
    Std::Print::Bits::Hex(FUT(0b1111)); Print("\n");
    // CHECK: Evaluation error: assertion failure

    return 0;
end
