function Test0(w : Integer) -> Bits(0)
begin
    return Std::Bits::Mk_Mask(w, 0);
end

function Test8(w : Integer) -> Bits(8)
begin
    return Std::Bits::Mk_Mask(w, 8);
end

function main() -> Integer
begin
    Std::Print::Bits::Hex(Test0(0)); Print("\n");
    // CHECK: 0'x0
    Std::Print::Bits::Hex(Test8(3)); Print("\n");
    // CHECK: 8'x7
    return 0;
end
