function Test(x : Integer, y : Integer) -> Boolean
begin
    return x <= y;
end

function main() -> Integer
begin
    Std::Print::Boolean(Test(1, 2)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(Test(1, 1)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(Test(1, 0)); Std::Print::String("\n");
    // CHECK: False
    Std::Print::Boolean(Test(-1, 0)); Std::Print::String("\n");
    // CHECK: True
    return 0;
end
