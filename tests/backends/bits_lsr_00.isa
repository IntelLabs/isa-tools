function Test(x : Bits(8), y : Integer) -> Bits(8)
begin
    return Std::Bits::Shift_Right_Logical_Restricted(x, y);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(0b1010_0101, 3)); Print("\n");
    // CHECK: 8'x14
    Std::Print::Bits::Hex(Test(0b0101_1010, 2)); Print("\n");
    // CHECK: 8'x16
    return Builtin::Foreign::CInt::From_Integer(0);
end
