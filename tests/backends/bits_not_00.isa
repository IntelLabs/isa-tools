function Test(x : Bits(8)) -> Bits(8)
begin
    return (not x);
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(0b1011_0011)); Print("\n");
    // CHECK: 8'x4c
    return Builtin::Foreign::CInt::From_Integer(0);
end
