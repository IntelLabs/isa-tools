// RUN: %aslrun %s --transform-foreign --extra-c=%S/ffi_export_02.c | filecheck %s
// Copyright (C) 2025-2025 Intel Corporation

// UNSUPPORTED: interpreter

// Functions which allow reading/writing the exported variable from C will be
// generated. The names of the functions are derived from the variable name
// by adding _Read or _Write suffixes.

// Helper function imported from C
function Helper() -> ();
foreign import function "Helper" = Helper with {};

var v : Integer;

foreign export var "v" = v;

function main() -> Integer
begin
    v := 1;
    Helper();
    Std::Print::Integer::Dec(v); Print("\n");
    // CHECK: 2

    return 0;
end
