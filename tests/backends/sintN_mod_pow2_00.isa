function FUT(x : __sint(8), y : __sint(8)) -> __sint(8)
begin
    return Std::SInt::Mod_Power_Of_Two(x, y);
end

function main() -> Integer
begin
    Std::Print::SInt::Dec(FUT(i8'd12, i8'd2)); Print("\n");
    // CHECK: i8'd0
    Std::Print::SInt::Dec(FUT(i8'd13, i8'd2)); Print("\n");
    // CHECK: i8'd1
    Std::Print::SInt::Dec(FUT(i8'd14, i8'd2)); Print("\n");
    // CHECK: i8'd2
    Std::Print::SInt::Dec(FUT(i8'd15, i8'd2)); Print("\n");
    // CHECK: i8'd3
    Std::Print::SInt::Dec(FUT(i8'd16, i8'd2)); Print("\n");
    // CHECK: i8'd0
    return 0;
end
