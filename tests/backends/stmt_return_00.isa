function FUT(x : Boolean) -> Boolean
begin
    return x;
end

function main() -> Integer
begin
    Std::Print::Boolean(FUT(True)); Std::Print::String("\n");
    // CHECK: True
    Std::Print::Boolean(FUT(False)); Std::Print::String("\n");
    // CHECK: False

    return 0;
end
