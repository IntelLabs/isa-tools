// RUN: %aslrun %s | filecheck %s
// Copyright (C) 2023-2026 Intel Corporation

exception E0;
exception E1 = { payload : Boolean };
exception E2;

function FUT?(x : Integer) -> Integer
begin
    if x == 0 then
        throw E0;
    elsif x == 1 then
        throw E1{ payload=>True };
    elsif x == 2 then
        throw E1{ payload=>False };
    elsif x == 3 then
        throw E2;
    else
        return 42;
    end;
    return -1;
end

function FUT2(x : Integer)
begin
    try
        Std::Print::Integer::Hex(FUT?(x)); Print("\n");
        Std::Print::String("Did not throw\n");
    catch
        when e : E0 => Std::Print::String("Caught exception E0\n");
        when e : E1 =>
            if e.payload then
                Std::Print::String("Caught exception E1{True}\n");
            else
                Std::Print::String("Caught exception E1{False}\n");
            end;
        otherwise =>
            Std::Print::String("Caught another exception\n");
    end;
    Std::Print::String("Exited try block\n");
end

function main() -> Builtin::Foreign::CInt
begin
    FUT2(0);
    // CHECK: Caught exception E0
    // CHECK: Exited try block

    FUT2(1);
    // CHECK: Caught exception E1{True}
    // CHECK: Exited try block

    FUT2(2);
    // CHECK: Caught exception E1{False}
    // CHECK: Exited try block

    FUT2(3);
    // CHECK: Caught another exception
    // CHECK: Exited try block

    FUT2(4);
    // CHECK: 0x2a
    // CHECK: Did not throw
    // CHECK: Exited try block

    return Builtin::Foreign::CInt::From_Integer(0);
end

