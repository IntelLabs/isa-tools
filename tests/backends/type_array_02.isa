let R : array [3] of Bits(32) := array(32'x3, 32'x4, 32'x5);

function Test(i : Integer) -> Bits(32)
begin
    return R[i];
end

function main() -> Builtin::Foreign::CInt
begin
    Std::Print::Bits::Hex(Test(0)); Print("\n");
    // CHECK: 32'x3
    Std::Print::Bits::Hex(Test(1)); Print("\n");
    // CHECK: 32'x4
    Std::Print::Bits::Hex(Test(2)); Print("\n");
    // CHECK: 32'x5

    return Builtin::Foreign::CInt::From_Integer(0);
end

